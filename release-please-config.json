{
  "pull-request-title-pattern": "chore: release ${version}",
  "release-type": "python",
  "include-component-in-tag": false,
  "packages": {
    ".": {
      "package-name": "sqlalchemy-deprecated-column",
      "extra-files": [
        {
          "path": "uv.lock",
          "type": "toml",
          "jsonpath": "$.package[?(@.name.value=='sqlalchemy-deprecated-column')].version"
        }
      ]
    }
  }
}
